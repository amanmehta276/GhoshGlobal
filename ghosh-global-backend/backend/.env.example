# MongoDB Atlas connection string
# Get this from: Atlas → Connect → Drivers → Python
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
MONGODB_URL=mongodb+srv://Aman:Mehta123@clustor0.7ubfnrj.mongodb.net/?appName=clustor0

# Database name (can leave as is)
DB_NAME=ghoshglobal

# Admin panel password — Debasis uses this to log in
ADMIN_PASSWORD=BengalDebasis

# JWT secret — random string, keep it secret
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=jdkacbdsucbedviybdfyevbdwiuvvdbdwvuwbvicbeuvcowbwjhvbjhyjbewukbvyrivbo9ewubnodkjou9ewvbvucuu9bwc93brv93rvbr37rfb93

# Allowed frontend origins (comma separated, no spaces)
# Add your Netlify URL once deployed
ALLOWED_ORIGINS=http://localhost,https://ghoshglobal.netlify.app,https://ghoshglobal.com
